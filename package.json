{
  "name": "portfolio-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "quality": "pnpm lint && pnpm format:check && pnpm typecheck",
    "audit": "pnpm audit --audit-level=high",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:trace": "DEBUG=1 playwright test --headed",
    "test:e2e:single": "playwright test tests/e2e/smoke.spec.ts --headed",
    "secrets:scan": "trufflehog filesystem . --debug --only-verified",
    "registry:validate": "tsx src/lib/registry.ts --validate",
    "registry:list": "tsx src/lib/registry.ts --list",
    "env:validate": "tsx scripts/env-validate.ts",
    "links:check": "pnpm test:e2e",
    "links:check:external": "tsx scripts/external-links-monitor.ts",
    "analyze:bundle": "ANALYZE=true pnpm build",
    "analyze:build": "node -e \"const { execSync } = require('node:child_process'); const start = Date.now(); execSync('next build', { stdio: 'inherit' }); console.log('Build time (s):', ((Date.now() - start) / 1000).toFixed(2));\"",
    "pr:remediate": "bash ./scripts/backport-pr-remediation.sh",
    "verify": "./scripts/verify-local.sh",
    "verify:quick": "./scripts/verify-local.sh --skip-tests --skip-performance"
  },
  "dependencies": {
    "@proj-airi/font-departure-mono": "^0.10.2",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "js-yaml": "^4.3.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.6",
    "@vitest/ui": "^3.2.6",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-security": "^3.0.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^3.2.6",
    "wait-on": "^9.0.10"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.16.0",
      "flatted": "^3.4.2",
      "undici": "^7.28.0",
      "lodash": "^4.18.0",
      "vite": "^7.3.5",
      "vitest>vite": "^7.3.5",
      "@vitest/mocker>vite": "^7.3.5",
      "next": "16.2.9",
      "form-data": "^4.0.6",
      "ws": "^7.5.11",
      "micromatch@4>picomatch": "^2.3.2",
      "picomatch@4.0.3": "^4.0.4"
    }
  },
  "packageManager": "pnpm@10.0.0"
}
